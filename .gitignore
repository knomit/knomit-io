# local planning packet (kept out of the published repo)
local/
# root-only: the planning packet, NOT nested dirs like src/pages/docs or
# src/content/docs (an unanchored `docs/` would swallow those too).
/docs/
.claude/plans/
.superpowers/

# dependencies
node_modules/

# build output
dist/
.astro/

# generated at build time by scripts/sync.mjs (pulled from the knomit source)
src/generated/*
!src/generated/.gitkeep
public/openapi.yaml

# test artifacts
test-results/
playwright-report/
.playwright/
.playwright-mcp/

# env & os
.env
.env.*
!.env.example
.DS_Store
