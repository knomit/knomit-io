# Optional. Copy to .env (gitignored); it's auto-loaded by the sync step.
# A sibling ../knomit checkout is auto-detected, so usually nothing here is needed.
SITE_URL=https://knomit.io
# Override the knomit source location (only if it isn't a sibling ../knomit):
# KNOMIT_SRC=/path/to/knomit
KNOMIT_REF=main
KNOMIT_REPO_SLUG=knomit/knomit
# GITHUB_TOKEN=   # for fetching openapi.yaml from a private GitHub repo
