---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'start' | 'center';
}
const { eyebrow, title, lead, align = 'start' } = Astro.props;
---

<div class={`k-heading k-heading--${align}`}>
  {eyebrow && <p class="k-eyebrow">{eyebrow}</p>}
  <h2 class="k-heading__title">{title}</h2>
  {lead && <p class="k-lead k-heading__lead">{lead}</p>}
</div>

<style>
  .k-heading {
    margin-bottom: 2.5rem;
  }
  .k-heading--center {
    text-align: center;
    max-width: 42rem;
    margin-inline: auto;
  }
  .k-heading__title {
    font-size: var(--k-step-h2);
  }
  .k-heading__lead {
    margin-top: 1rem;
    max-width: 40rem;
  }
  .k-heading--center .k-heading__lead {
    margin-inline: auto;
  }
</style>
