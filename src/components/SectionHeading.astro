---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'start' | 'center';
  /** Heading level for the title. Use 'h1' on a page's primary heading so the
   *  page has exactly one H1; defaults to 'h2' for subsequent section headings.
   *  Purely semantic — the .k-heading__title class fixes the visual size. */
  as?: 'h1' | 'h2';
}
const { eyebrow, title, lead, align = 'start', as: Tag = 'h2' } = Astro.props;
---

<div class={`k-heading k-heading--${align}`}>
  {eyebrow && <p class="k-eyebrow">{eyebrow}</p>}
  <Tag class="k-heading__title">{title}</Tag>
  {lead && <p class="k-lead k-heading__lead">{lead}</p>}
</div>

<style>
  .k-heading {
    margin-bottom: 2.5rem;
  }
  .k-heading--center {
    text-align: center;
    max-width: 42rem;
    margin-inline: auto;
  }
  .k-heading__title {
    font-size: var(--k-step-h2);
  }
  .k-heading__lead {
    margin-top: 1rem;
    max-width: 40rem;
  }
  .k-heading--center .k-heading__lead {
    margin-inline: auto;
  }
</style>
