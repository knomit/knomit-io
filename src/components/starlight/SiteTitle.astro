---
// Match the marketing header brand exactly: the node-graph logo mark plus the
// "knomit" wordmark in the display face — not Starlight's accent-colored title.
import Logo from '../../assets/logo.svg';
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex" translate="no" aria-label="knomit home">
  <Logo width={30} height={30} />
  <span class="wordmark">knomit</span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: 0.55rem;
    color: var(--k-text);
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
    padding: 0.25rem;
    margin: -0.25rem;
  }
  .site-title:hover {
    color: var(--k-text);
  }
  .wordmark {
    font-family: var(--k-font-display);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    overflow: hidden;
  }
</style>
