---
// Carry the marketing site's primary navigation into the docs header so /docs
// reads as one site, not a bolted-on doc tool. Replaces Starlight's social row
// (we keep GitHub here as the single icon link).
import { GITHUB_URL, DEMO_LIVE } from '../../lib/site';

const nav = [
  { label: 'Concepts', href: '/concepts' },
  { label: 'Use cases', href: '/use-cases' },
  { label: 'Blog', href: '/blog' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<nav class="docs-topnav" aria-label="Site">
  {
    nav.map((item) => (
      <a
        href={item.href}
        class="docs-topnav__link"
        aria-current={isActive(item.href) ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))
  }
  {DEMO_LIVE && <a href="/explore" class="docs-topnav__link docs-topnav__link--demo">See it live</a>}
  <a href={GITHUB_URL} class="docs-topnav__gh" rel="noopener" aria-label="knomit on GitHub">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
      <path
        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
      ></path>
    </svg>
  </a>
</nav>

<style>
  .docs-topnav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.85rem 1.25rem;
  }
  .docs-topnav__link {
    color: var(--k-text-2);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
  }
  .docs-topnav__link:hover {
    color: var(--k-text);
  }
  .docs-topnav__link[aria-current='page'] {
    color: var(--k-brand);
  }
  .docs-topnav__link--demo {
    color: var(--k-brand);
  }
  .docs-topnav__gh {
    display: inline-flex;
    align-items: center;
    color: var(--k-text-2);
    padding: 0.35rem;
    margin: -0.35rem;
  }
  .docs-topnav__gh:hover {
    color: var(--k-text);
  }

  /* In the header's cramped width band the search box needs the room, so hide
     the site links there. The mobile menu footer still renders them in full. */
  @media (max-width: 72rem) {
    :global(.right-group) .docs-topnav__link {
      display: none;
    }
  }
</style>
