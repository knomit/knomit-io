---
import BaseLayout from '../layouts/BaseLayout.astro';
import KnowledgeGraph from '../components/KnowledgeGraph.astro';
import FragmentedKnowledge from '../components/FragmentedKnowledge.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FactCard from '../components/FactCard.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Steps from '../components/Steps.astro';
import BlogCard from '../components/BlogCard.astro';
import Icon from '../components/Icon.astro';
import { GITHUB_URL, SITE_DESCRIPTION } from '../lib/site';
import { getPublishedPosts, postHref } from '../lib/blog';

const posts = (await getPublishedPosts()).slice(0, 3);

// The nine characteristics worth highlighting — each a distinct differentiator
// rooted in a knomit-kb designer principle. Renders as a 3×3 grid.
const pillars = [
  {
    icon: 'fact',
    title: 'Facts, not documents',
    body: 'Concise, atomic claims — observations, principles, invariants, decisions — not chunked text in a vector store.',
  },
  {
    icon: 'kinds',
    title: 'Typed by how it’s used',
    body: 'Every fact is epistemic (what is) or pragmatic (what to do), each carrying a confidence you can weigh — and that rises and falls.',
  },
  {
    icon: 'dedup',
    title: 'Never learned twice',
    body: 'Similar inputs subsume into one fact with many references. And what one peer learns, every peer inherits by pulling main — no re-deriving what the network already knows.',
  },
  {
    icon: 'provenance',
    title: 'Provable provenance',
    body: 'Every fact is a signed commit you can trace, cross-reference, and corroborate — where a claim came from, who asserted it, and how it changed. Cryptographic, not hand-waved.',
  },
  {
    icon: 'temporal',
    title: 'A graph you read as-of',
    body: 'Git versions the whole graph by commit. Follow a fact’s references as the world was when it was learned — not as it is now — and watch confidence move over time.',
  },
  {
    icon: 'discovery',
    title: 'Discovery compounds',
    body: 'Synthesis distills higher-order facts from what you already know, and hypotheses extend them — knowledge that generates new knowledge.',
  },
  {
    icon: 'cluster',
    title: 'Self-describing & clustered',
    body: 'Every fact declares its ontology, domains, and entities — and clusters by meaning and by classification, so you see the shape of everything you know.',
  },
  {
    icon: 'mcp',
    title: 'MCP-native, in the loop',
    body: 'Drops into Claude Code, your editor, or any agent over MCP. The same tools let a model recall before it acts and learn as it works — no prompt scaffolding.',
  },
  {
    icon: 'consensus',
    title: 'Autonomy with consensus — it’s just git',
    body: 'Each peer works on its own branch; facts are approved and merged into main, the consensus. It’s a plain git repo — review like code, host it anywhere.',
  },
];

// The anatomy of the fact on the card — what each part means.
const factTraits = [
  { icon: 'kinds', text: 'A kind — epistemic (what is) or pragmatic (what to do) — so a consumer knows how to apply it.' },
  { icon: 'temporal', text: 'A confidence — a degree of belief, not a true/false flag.' },
  { icon: 'ontology', text: 'An ontology path, domains, and entities — what it’s about, and where it lives.' },
  { icon: 'provenance', text: 'Refs — to its sources and to other facts, forming the graph.' },
  { icon: 'markdown', text: 'One claim, in plain markdown — human- and machine-writable, diffable in git.' },
];

const steps = [
  {
    n: '01',
    title: 'Assert a fact, in the flow of work',
    body: 'Learning isn’t a side chore. Through MCP — wired into Claude Code, your editor, or any agent — a peer asserts a typed claim as part of its normal execution: it learns while it works. Humans assert the same way, by editing markdown.',
    code: 'knomit_learn (MCP)  ·  Claude Code · editor · agent loop',
  },
  {
    n: '02',
    title: 'It’s a signed commit on a versioned graph',
    body: 'Each write is one atomic, signed git commit on the peer’s own branch — never on main directly. Commits chain into a versioned, time-based graph: every fact is pinned to the exact moment, and the exact state of the world, in which it was learned.',
    code: 'commit a1ef27c  ·  signed (Ed25519)  ·  branch agent/…',
  },
  {
    n: '03',
    title: 'Reach consensus — it’s just git',
    body: 'No peer merges another’s branch. Facts are reviewed, approved, and merged into main — the consensus. Because the store is a plain git repo, you can keep it local or push to a git host like GitHub: a decentralized, always-on, secured remote with pull-request review and merge built in. Each peer then pulls main and merges it locally.',
    code: 'git: local repo or remote (GitHub) → PR review → merge to main',
  },
  {
    n: '04',
    title: 'Travel the graph in time',
    body: 'Because the graph is versioned by commit, knomit_explain follows every reference as the world was when the fact was learned — not as it is now. Replay how a claim evolved; let synthesis distill new facts and hypotheses extend them forward.',
    code: 'knomit_explain (as-of commit) · synthesis · hypothesis',
  },
];
---

<BaseLayout
  title="knomit — Distributed, decentralized knowledge base"
  description={SITE_DESCRIPTION}
>
  <!-- Hero -->
  <section class="hero k-grid-bg">
    <div class="k-container hero__inner">
      <div class="hero__copy">
        <p class="k-eyebrow">Distributed knowledge · Knowledge + commit</p>
        <h1 class="hero__title">Learn it once.<br />Everywhere knows.</h1>
        <p class="k-lead hero__lead">
          A distributed knowledge base built from concise, typed
          <strong>facts</strong> — not ingested documents. Each fact carries
          confidence, provenance, and refs to others; facts evolve, and discovery
          gives birth to new ones. Every peer — human or agent — learns on its own
          branch and converges on a shared <code>main</code>.
        </p>
        <div class="hero__cta">
          <a href={GITHUB_URL} class="k-btn" rel="noopener">
            <Icon name="provenance" size={17} /> View on GitHub
          </a>
          <a href="/docs/quick-start" class="k-btn k-btn--ghost">
            Quick start <Icon name="arrow" size={17} />
          </a>
        </div>
        <p class="hero__sub k-mono k-muted">
          facts, not documents · signed commits · converge on main
        </p>
      </div>
      <div class="hero__art">
        <KnowledgeGraph />
      </div>
    </div>
  </section>

  <!-- Facts, not documents (foundational) -->
  <section class="k-section facts">
    <div class="k-container facts__grid">
      <div class="facts__copy">
        <SectionHeading
          eyebrow="Facts, not documents"
          title="Anatomy of a fact."
          lead="knomit is not chunk-and-embed. Knowledge is captured as facts — atomic claims in plain markdown. Here's what one is made of."
        />
        <ul class="facts__list">
          {
            factTraits.map((t) => (
              <li>
                <Icon name={t.icon as any} size={18} /> {t.text}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="facts__art k-reveal">
        <FactCard />
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="k-section problem-section">
    <div class="k-container">
      <div class="problem-head">
        <div class="k-prose">
          <SectionHeading
            eyebrow="The problem"
            title="Other systems store text — not understanding."
            lead="Ingest a document and you've stored its words, not what's true in it. Two similar documents become two copies instead of one set of facts — and you can't explain, corroborate, or trace any of it."
          />
        </div>
        <div class="problem-head__art k-reveal">
          <FragmentedKnowledge />
        </div>
      </div>
      <p class="problem-group k-mono">In your documents</p>
      <div class="problems">
        <div class="problem k-reveal">
          <h3>Text, not comprehension</h3>
          <p class="k-text-2">
            RAG and friends embed whole documents as-is. You store the text, not
            the facts inside it — no concise, classified claims you can reason over.
          </p>
        </div>
        <div class="problem k-reveal">
          <h3>Duplicated, not unified</h3>
          <p class="k-text-2">
            Two documents that say nearly the same thing get stored twice — not as
            one fact with multiple references, just redundant chunks that drift.
          </p>
        </div>
        <div class="problem k-reveal">
          <h3>No way to explain it</h3>
          <p class="k-text-2">
            The document is used as-is: no cross-reference, no corroboration, no
            confidence, no going back in time to see how a claim evolved.
          </p>
        </div>
      </div>

      <p class="problem-group k-mono">In your codebase</p>
      <div class="problems">
        <div class="problem k-reveal">
          <h3>Principles get lost</h3>
          <p class="k-text-2">
            Design intent lives in someone's head, not the repo — so agents and
            teammates slowly drift from how things are meant to work.
          </p>
        </div>
        <div class="problem k-reveal">
          <h3>Invariants stay hidden</h3>
          <p class="k-text-2">
            The load-bearing rules aren't written where the work happens, so the
            same mistakes get made again and again.
          </p>
        </div>
        <div class="problem k-reveal">
          <h3>Decisions aren't kept</h3>
          <p class="k-text-2">
            Why an approach was tried and dropped goes unrecorded — so dead-end
            experiments get repeated from scratch.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="k-section">
    <div class="k-container">
      <SectionHeading
        eyebrow="How it works"
        title="A learning loop that closes."
        lead="Asserted, proven, agreed, recalled — the loop runs inside your normal workflow, not beside it."
        align="center"
      />
      <div class="howit">
        <Steps steps={steps} />
      </div>
      <div class="loop k-reveal">
        <span class="loop__icon" aria-hidden="true">
          <Icon name="evolve" size={20} />
        </span>
        <div>
          <h3 class="loop__title">The loop closes</h3>
          <p class="k-text-2 loop__body">
            The same MCP tools and skills that let your model <em>act</em> let it
            <em>introspect</em> on what it knows — recall before it works, learn as
            it goes. Every pass leaves the knowledge base sharper than it found it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section class="k-section features">
    <div class="k-container">
      <SectionHeading
        eyebrow="Why knomit"
        title="What production knowledge needs."
        lead="Decisions are only as good as the facts behind them. knomit is built so those facts are accurate, traceable, and actionable — across every peer."
        align="center"
      />
      <FeatureGrid features={pillars} />
    </div>
  </section>

  <!-- From the blog -->
  {
    posts.length > 0 && (
      <section class="k-section">
        <div class="k-container">
          <div class="blogstrip__head">
            <SectionHeading eyebrow="From the blog" title="Real-world use cases." />
            <a href="/blog" class="k-blogstrip__all">All posts <Icon name="arrow" size={16} /></a>
          </div>
          <div class="blogstrip">
            {posts.map((post) => (
              <BlogCard
                href={postHref(post)}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Footer CTA -->
  <section class="k-section">
    <div class="k-container">
      <div class="cta k-reveal">
        <h2 class="cta__title">One source of truth. Every peer.</h2>
        <p class="k-lead cta__lead">
          Open source, and it's just git — typed, provenanced facts, versioned
          through time, that humans and agents converge on. Yours to inspect,
          diff, and host anywhere.
        </p>
        <div class="cta__actions">
          <a href={GITHUB_URL} class="k-btn" rel="noopener">View on GitHub</a>
          <a href="/docs/quick-start" class="k-btn k-btn--ghost">Quick start</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-block: clamp(3rem, 1.5rem + 7vw, 7rem);
    border-bottom: 1px solid var(--k-hairline-soft);
    position: relative;
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: clamp(2rem, 1rem + 4vw, 4rem);
    align-items: center;
  }
  .hero__title {
    font-size: var(--k-step-hero);
    margin: 0.5rem 0 0;
  }
  .hero__lead {
    margin-top: 1.5rem;
    max-width: 38rem;
  }
  .hero__lead strong {
    color: var(--k-brand);
    font-weight: 600;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }
  .hero__sub {
    margin-top: 1.25rem;
    font-size: 0.82rem;
  }
  .hero__art {
    max-width: 560px;
    margin-inline: auto;
    width: 100%;
  }

  /* Facts section */
  .facts {
    background: var(--k-surface-1);
    border-bottom: 1px solid var(--k-hairline-soft);
  }
  .facts__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 1rem + 4vw, 4rem);
    align-items: center;
  }
  .facts__list {
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }
  .facts__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    color: var(--k-text);
    font-size: 0.98rem;
    line-height: 1.4;
  }
  .facts__list :global(.k-icon) {
    color: var(--k-brand);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .facts__art {
    max-width: 440px;
  }

  /* Problem */
  .problem-head {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(1.5rem, 0.5rem + 4vw, 3.5rem);
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .problem-head__art {
    max-width: 400px;
    margin-inline: auto;
  }
  .problems {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .problem-group {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--k-text-muted);
    margin: 2.25rem 0 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .problem-group::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--k-hairline-soft);
  }
  .problem-group:first-of-type {
    margin-top: 0.5rem;
  }
  .problem {
    border-left: 2px solid var(--k-retracted);
    padding-left: 1.1rem;
  }
  .problem h3 {
    font-size: 1.12rem;
    margin-bottom: 0.5rem;
  }
  .problem p {
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .howit {
    max-width: 52rem;
    margin-inline: auto;
  }
  .loop {
    max-width: 52rem;
    margin: 2.5rem auto 0;
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--k-hairline);
    border-radius: var(--k-radius);
    background:
      radial-gradient(120% 160% at 0% 0%, var(--k-brand-glow), transparent 55%),
      var(--k-surface-1);
  }
  .loop__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    border-radius: 11px;
    color: var(--k-brand);
    background: var(--k-brand-glow);
    border: 1px solid rgba(119, 204, 153, 0.25);
  }
  .loop__title {
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
  }
  .loop__body {
    line-height: 1.6;
    font-size: 0.96rem;
  }
  .loop__body em {
    color: var(--k-brand);
    font-style: normal;
    font-weight: 600;
  }

  /* Demo */
  .demo {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: clamp(2rem, 1rem + 4vw, 3.5rem);
    border: 1px solid var(--k-hairline);
    border-radius: var(--k-radius-lg);
    background-color: var(--k-surface-1);
  }
  .demo h2 {
    font-size: var(--k-step-h2);
    margin-top: 0.3rem;
  }
  .demo__lead {
    margin: 1rem 0 1.75rem;
    max-width: 34rem;
    line-height: 1.6;
  }
  .demo__badge {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem 1.4rem;
    border: 1px dashed var(--k-hairline);
    border-radius: var(--k-radius);
    background: var(--k-bg);
    font-size: 0.82rem;
    color: var(--k-brand);
  }

  /* Blog strip */
  .blogstrip__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }
  .blogstrip__head :global(.k-heading) {
    margin-bottom: 1.5rem;
  }
  .k-blogstrip__all {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.92rem;
    white-space: nowrap;
    margin-bottom: 1.75rem;
  }
  .blogstrip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  /* CTA */
  .cta {
    text-align: center;
    padding: clamp(2.5rem, 1.5rem + 5vw, 5rem) 1.5rem;
    border: 1px solid var(--k-hairline);
    border-radius: var(--k-radius-lg);
    background:
      radial-gradient(120% 140% at 50% 0%, var(--k-brand-glow), transparent 60%),
      var(--k-surface-1);
  }
  .cta__title {
    font-size: var(--k-step-h1);
    max-width: 20ch;
    margin-inline: auto;
  }
  .cta__lead {
    margin: 1.1rem auto 2rem;
    max-width: 38rem;
  }
  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
  }

  @media (max-width: 880px) {
    .hero__inner,
    .facts__grid,
    .problem-head {
      grid-template-columns: 1fr;
    }
    .hero__art {
      order: -1;
      max-width: 340px;
    }
    .facts__art {
      margin-inline: auto;
    }
    /* the contrast art is decorative; drop it on small screens to save height */
    .problem-head__art {
      display: none;
    }
  }
</style>
