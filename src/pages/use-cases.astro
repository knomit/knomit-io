---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Icon from '../components/Icon.astro';
import { GITHUB_URL, DEMO_LIVE } from '../lib/site';

const groups = [
  {
    eyebrow: 'For developers & their coding agents',
    lead: 'Knowledge that lives where the work happens.',
    cases: [
      {
        icon: 'ontology',
        title: 'Codebase tribal knowledge',
        body: 'Invariants, gotchas, and design rationale that never make it into comments. Your coding agent — and your teammates — read them before touching an area, and write new ones when they discover something non-obvious.',
        tag: 'invariants · gotchas · decisions — in the repo',
      },
      {
        icon: 'provenance',
        title: 'Agents that document their own decisions',
        body: 'When an agent makes a call — picks an approach, rejects an alternative, resolves a tradeoff — it records it as a typed, signed fact. Not memory: actionable knowledge. The next agent reads the rationale instead of re-deriving it, and you can trace exactly what was known when any choice was made.',
        tag: 'self-documenting · signed · traceable',
      },
    ],
  },
  {
    eyebrow: 'For researchers & analysts',
    lead: 'A corpus that sharpens itself.',
    cases: [
      {
        icon: 'search',
        title: 'Research & intelligence monitoring',
        body: 'Point agents at sources; they learn typed facts continuously. Synthesis distills patterns and higher-order insight as the corpus grows — exactly what the live demo shows.',
        tag: 'continuous learning · synthesis · the live demo',
        link: DEMO_LIVE ? { href: '/explore', label: 'Open the live demo' } : undefined,
      },
      {
        icon: 'discovery',
        title: 'Hypothesis-driven research',
        body: 'Observations distill into syntheses; syntheses extend into falsifiable hypotheses with settlement criteria. When evidence arrives, the hypothesis transitions to observation — and git records the exact moment the loop closed.',
        tag: 'observe → synthesize → hypothesize → confirm',
        link: { href: '/concepts#synthesis', label: 'Synthesis & hypotheses' },
      },
      {
        icon: 'evolve',
        title: 'Knowledge that compounds',
        body: 'Facts beget facts; confidence rises and falls; query the graph as-of any point in time — so the corpus gets sharper over time, not just bigger.',
        tag: 'confidence moves · query as-of any commit',
        link: { href: '/concepts#temporal', label: 'The temporal graph' },
      },
    ],
  },
  {
    eyebrow: 'For fleets & open networks',
    lead: 'Many minds, one converging truth.',
    cases: [
      {
        icon: 'consensus',
        title: 'Distributed team knowledge',
        body: 'One source of truth that humans and agents build together. Because facts are plain markdown in git, you review knowledge in pull requests and trust provenance instead of folklore.',
        tag: 'author together · review like code',
        link: { href: '/concepts#branches', label: 'Peers, branches & consensus' },
      },
      {
        icon: 'cluster',
        title: 'Competitive agent benchmarking',
        body: 'Spin a fleet at one task; each agent self-documents its approach and findings on its own branch; all converge to a shared repo. Synthesis distills where approaches agreed, where confidence diverged, and what only one agent found — a knowledge graph of why, not just a leaderboard.',
        tag: 'fleet · per-branch findings · distilled comparison',
      },
      {
        icon: 'distributed',
        title: 'Open knowledge networks',
        body: 'A public knomit repo anyone contributes to via pull request — a shared commons with full provenance, where deduplication means the network pays each learning cost once.',
        tag: 'public repo · PR contributions · paid once',
      },
    ],
  },
  {
    eyebrow: 'For decentralized & edge deployment',
    lead: 'It\'s just git — so it goes anywhere, and composes any way.',
    cases: [
      {
        icon: 'mcp',
        title: 'Knowledge processing pipelines',
        body: 'Instances compose. One instance points at a repo hosted by another, so you can wire a DAG: a raw-ingestion node feeds a distillation node feeds a consensus node. An ETL pipeline for facts, where every stage is itself a queryable knomit.',
        tag: 'compose instances · ingest → distill → consensus',
      },
      {
        icon: 'fact',
        title: 'Offline-first & edge agents',
        body: 'Every peer holds the entire knowledge base locally as a git repo. An agent in the field, airgapped, or simply disconnected has full recall and keeps learning on its branch — then syncs when it reconnects. The network is for consensus, not for access.',
        tag: 'local-first · works disconnected · syncs later',
      },
    ],
  },
];
---

<BaseLayout
  title="Use cases — knomit"
  description="Ten things you can build on a git-native, fact-based knowledge base — for developers and coding agents, researchers, fleets and open networks, and decentralized edge deployment."
>
  <section class="k-section uc-hero k-grid-bg">
    <div class="k-container">
      <SectionHeading
        eyebrow="Use cases"
        title="Where shared, proven knowledge pays off."
        lead="The same git-native substrate serves a solo developer, a research fleet, and a whole network of people and agents. A pool of what people build with it."
      />
    </div>
  </section>

  {
    groups.map((group) => (
      <section class="k-section uc-group">
        <div class="k-container">
          <header class="uc-group__head">
            <p class="k-eyebrow">{group.eyebrow}</p>
            <p class="uc-group__lead">{group.lead}</p>
          </header>
          <div class="uc-grid">
            {group.cases.map((c) => (
              <article class="k-card uc-card k-reveal">
                <span class="uc-card__icon">
                  <Icon name={c.icon as any} size={22} />
                </span>
                <h2 class="uc-card__title">{c.title}</h2>
                <p class="uc-card__body k-text-2">{c.body}</p>
                <p class="uc-card__tag k-mono">{c.tag}</p>
                {c.link && (
                  <a href={c.link.href} class="uc-card__link">
                    {c.link.label} <Icon name="arrow" size={15} />
                  </a>
                )}
              </article>
            ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="k-section">
    <div class="k-container uc-cta">
      <h2>Have a use case of your own?</h2>
      <p class="k-lead">It's open source. Clone it, point your peers at it, and see.</p>
      <div class="uc-cta__actions">
        <a href={GITHUB_URL} class="k-btn" rel="noopener">View on GitHub</a>
        <a href="/docs/quick-start" class="k-btn k-btn--ghost">Quick start</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .uc-hero {
    border-bottom: 1px solid var(--k-hairline-soft);
    padding-block: clamp(3rem, 2rem + 4vw, 4.5rem) 1rem;
  }
  .uc-hero :global(.k-heading) {
    margin-bottom: 0;
  }
  .uc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
  }
  .uc-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
  }
  .uc-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 11px;
    color: var(--k-brand);
    background: var(--k-brand-glow);
    border: 1px solid rgba(119, 204, 153, 0.25);
    margin-bottom: 1.1rem;
  }
  .uc-card__title {
    font-size: 1.4rem;
    margin-bottom: 0.7rem;
  }
  .uc-card__body {
    line-height: 1.6;
    font-size: 0.96rem;
  }
  .uc-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0;
    padding-top: 0.5rem;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .uc-group {
    padding-block: clamp(2rem, 1.25rem + 3vw, 3.25rem);
  }
  .uc-group + .uc-group {
    padding-top: 0;
  }
  .uc-group__head {
    margin-bottom: 1.5rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--k-hairline-soft);
  }
  .uc-group__lead {
    font-size: 1.15rem;
    color: var(--k-text);
    margin-top: 0.3rem;
  }
  .uc-card__tag {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.76rem;
    color: var(--k-text-muted);
    letter-spacing: 0.01em;
  }
  /* When a card has both a tag and a link, the tag shouldn't eat the spacer */
  .uc-card__tag + .uc-card__link {
    margin-top: 0.6rem;
    padding-top: 0;
  }

  .uc-cta {
    text-align: center;
  }
  .uc-cta h2 {
    font-size: var(--k-step-h2);
    margin-bottom: 0.8rem;
  }
  .uc-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
    margin-top: 1.75rem;
  }
</style>
