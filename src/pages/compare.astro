---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Icon from '../components/Icon.astro';
import { GITHUB_URL, DEMO_LIVE } from '../lib/site';

// The field doesn't divide cleanly by product — it divides by *operational
// profile*. Naming tools dates fast and reads as combative; clustering by how a
// tool actually behaves is durable, honest, and — fittingly — exactly what
// knomit does to knowledge. (Internal decoder: local/comp/README.md.)
const clusters = [
  {
    icon: 'search',
    name: 'Raw piles & DIY',
    profile:
      'You wire up a vector store or a folder of notes yourself. Text goes in; similar text comes back.',
    strong:
      'Dead simple, no new dependency — fine for one-shot retrieval over a static set of documents.',
    exposed:
      'Nothing dedups or structures itself. Duplicates pile up, knowledge drifts, and every chunk is trusted equally with no idea where it came from.',
  },
  {
    icon: 'api',
    name: 'Recall layers',
    profile:
      'Drop in a memory API. It captures the conversation automatically and replays the relevant bits next time.',
    strong:
      'Low-effort continuity for a single assistant, with broad framework integrations.',
    exposed:
      'Memories are flat free text with no link back to their source, siloed per agent, and impossible to review or version like code.',
  },
  {
    icon: 'ontology',
    name: 'Graph engines',
    profile:
      'Run a graph database, ingest data into entities and relationships, and reason across multiple hops.',
    strong:
      'Structured, multi-hop reasoning — and, at best, genuine temporal awareness of when a fact held.',
    exposed:
      'Heavy infrastructure bound to a database you can’t diff in a pull request, with unsigned facts and updates that sometimes overwrite history.',
  },
  {
    icon: 'mcp',
    name: 'Agent runtimes',
    profile:
      'Adopt a whole stateful-agent platform; the agent edits its own memory as it runs.',
    strong:
      'Self-editing memory and stateful agents out of the box, with strong tooling around the runtime.',
    exposed:
      'You inherit the entire runtime, each agent keeps its own private silo, and the change history — where it exists — is unsigned.',
  },
];

// Plotted on two axes: X = stores text → refines knowledge, Y = siloed/opaque →
// shared/auditable. knomit sits alone in the top-right.
const mapNodes = [
  { label: 'Raw piles', x: 13, y: 13 },
  { label: 'Recall layers', x: 33, y: 25 },
  { label: 'Agent runtimes', x: 48, y: 43 },
  { label: 'Graph engines', x: 60, y: 55 },
  { label: 'knomit', x: 82, y: 85, knomit: true },
];

const refinery = [
  {
    icon: 'cluster',
    title: 'It distills, not just stores',
    body: 'Similar inputs subsume into one fact, then synthesis derives higher-order structure — clusters and the non-obvious bridges between them. The corpus sharpens as it grows instead of bloating.',
  },
  {
    icon: 'discovery',
    title: 'It forms hypotheses',
    body: 'Synthesis extends into falsifiable predictions with settlement criteria. When evidence arrives, a hypothesis becomes an observation. That is a research capability — reasoning forward — not a recall one.',
  },
  {
    icon: 'provenance',
    title: 'Every change is signed — and reversible',
    body: 'Each fact is an Ed25519-signed git commit. Because the substrate is git, knomit prunes and rewrites itself safely: nothing is ever lost, and every refinement is a commit you can review, diff, and revert.',
  },
  {
    icon: 'consensus',
    title: 'Knowledge converges across peers',
    body: 'Agents and humans propose facts on branches; review merges them to main. One reviewed source of truth, shared instead of siloed — the gap every other cluster leaves open.',
  },
];

const reach = [
  'Knowledge has to be shared and trusted across many agents and humans, not siloed inside one tool.',
  'You need to explain a claim — where it came from, how confident it is, how it changed.',
  'You want it reviewable like code and hostable anywhere: it’s just a git repo.',
  'You want the store to improve itself — dedup, synthesis, hypotheses — not merely hold text.',
];

const outgrow = [
  'You only need conversational recall for a single assistant, and that’s the whole job.',
  'A one-shot retrieval over a static document set already answers your questions.',
  'There’s nothing to dedup, explain, version, or share — raw similarity search is enough.',
];

const mapAria =
  'Positioning map. Horizontal axis runs from storing text to refining knowledge; vertical axis from siloed and opaque to shared and auditable. Raw piles and DIY sit in the lower-left, recall layers lower-center, agent runtimes in the middle, graph engines mid-right, and knomit alone in the upper-right — the only profile that both refines and audits.';
---

<BaseLayout
  title="knomit vs the AI-memory landscape — comparison"
  description="How knomit compares to the four operational profiles of AI memory — raw stores, recall layers, graph engines, and agent runtimes — across provenance, synthesis, confidence, consensus, and time-travel."
>
  <!-- Reframe + map -->
  <section class="k-section">
    <div class="k-container">
      <SectionHeading
        eyebrow="Comparison"
        title="The landscape, by operational profile."
        lead="The tools agents use for memory cluster into four profiles. Each is good at something. None of them refine what they store — or let you audit how it changed. That gap is where knomit lives."
      />

      <div
        class="cmp-map k-reveal"
        role="img"
        aria-label={mapAria}
      >
        <span class="cmp-map__frontier" aria-hidden="true"></span>
        <span class="cmp-map__axis cmp-map__axis--x" aria-hidden="true">
          stores text&nbsp; →&nbsp; refines knowledge
        </span>
        <span class="cmp-map__axis cmp-map__axis--y" aria-hidden="true">
          siloed / opaque&nbsp; →&nbsp; shared / auditable
        </span>
        {mapNodes.map((n) => (
          <span
            class={`cmp-node${n.knomit ? ' cmp-node--knomit' : ''}`}
            style={`left:${n.x}%; bottom:${n.y}%`}
          >
            {n.label}
          </span>
        ))}
      </div>
      <p class="cmp-note k-text-2">
        Everyone else accumulates. knomit refines — and signs its work.
      </p>
    </div>
  </section>

  <!-- The four clusters -->
  <section class="k-section cmp-clusters">
    <div class="k-container">
      <SectionHeading
        eyebrow="The four profiles"
        title="What each cluster is good at — and where it leaves you exposed."
        lead="Operational profiles describe what a system can do and how it behaves at runtime — capabilities, not brand names — so they stay stable even as tools churn. You’ll recognise where your stack sits."
        align="center"
      />
      <div class="cmp-grid">
        {clusters.map((c) => (
          <div class="cmp-card k-reveal">
            <span class="cmp-card__icon" aria-hidden="true">
              <Icon name={c.icon as any} size={20} />
            </span>
            <h3 class="cmp-card__title">{c.name}</h3>
            <p class="cmp-card__profile k-text-2">{c.profile}</p>
            <div class="cmp-card__row">
              <span class="cmp-card__k cmp-card__k--yes">Strong</span>
              <p>{c.strong}</p>
            </div>
            <div class="cmp-card__row">
              <span class="cmp-card__k cmp-card__k--no">Exposed</span>
              <p>{c.exposed}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- knomit: the refinery -->
  <section class="k-section cmp-refinery">
    <div class="k-container">
      <SectionHeading
        eyebrow="Where knomit sits"
        title="A fifth profile: the knowledge refinery."
        lead="knomit isn’t a better point on the memory axis — it’s on a different one. It refines the knowledge it holds, and signs every change so you can trust what it kept and what it dropped."
        align="center"
      />
      <div class="cmp-grid">
        {refinery.map((r) => (
          <div class="cmp-card cmp-card--brand k-reveal">
            <span class="cmp-card__icon" aria-hidden="true">
              <Icon name={r.icon as any} size={20} />
            </span>
            <h3 class="cmp-card__title">{r.title}</h3>
            <p class="cmp-card__profile k-text-2">{r.body}</p>
          </div>
        ))}
      </div>

      <p class="cmp-callout k-reveal">
        Provenance, time-travel, and synthesis aren’t three features. They’re
        one: <strong>a knowledge base that improves itself — and lets you audit
        every improvement.</strong>
      </p>

      <p class="cmp-underneath k-text-2">
        Underneath it all: typed atomic facts, not chunks; a customisable
        epistemic ontology you author in plain markdown; confidence that rises
        and falls with the evidence; and external references that keep
        provenance intact beyond the corpus.
      </p>
    </div>
  </section>

  <!-- Honest fit -->
  <section class="k-section">
    <div class="k-container">
      <SectionHeading
        eyebrow="Is it the right tool?"
        title="When to reach for knomit — and when not to."
        lead="We’d rather you pick the right cluster than the loudest one."
        align="center"
      />
      <div class="cmp-fit">
        <div class="cmp-fit__col cmp-fit__col--yes k-reveal">
          <h3 class="cmp-fit__head">
            <Icon name="provenance" size={17} /> Reach for knomit when…
          </h3>
          <ul class="cmp-fit__list">
            {reach.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="cmp-fit__col cmp-fit__col--no k-reveal">
          <h3 class="cmp-fit__head">A simpler cluster is fine when…</h3>
          <ul class="cmp-fit__list">
            {outgrow.map((f) => <li>{f}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="k-section">
    <div class="k-container cmp-cta">
      <h2>See knowledge compound, not drift.</h2>
      <p class="k-lead cmp-cta__lead">
        It’s open source and it’s just git. Clone it, point your agents at it,
        and watch the corpus sharpen itself.
      </p>
      <div class="cmp-cta__actions">
        <a href={GITHUB_URL} class="k-btn" rel="noopener">View on GitHub</a>
        <a href="/docs/quick-start" class="k-btn k-btn--ghost">
          Quick start <Icon name="arrow" size={16} />
        </a>
        {DEMO_LIVE && (
          <a href="/explore" class="k-btn k-btn--ghost">See it live</a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Positioning map ─────────────────────────────────────────────── */
  .cmp-map {
    position: relative;
    margin-top: 2.5rem;
    height: clamp(300px, 38vh, 400px);
    border: 1px solid var(--k-hairline);
    border-radius: var(--k-radius-lg);
    background:
      radial-gradient(115% 115% at 100% 0%, var(--k-brand-glow), transparent 46%),
      linear-gradient(0deg, var(--k-surface-1), var(--k-surface-1));
    overflow: hidden;
  }
  /* faint frontier the others never reach */
  .cmp-map__frontier {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--k-hairline-soft) 1px, transparent 1px),
      linear-gradient(to top, var(--k-hairline-soft) 1px, transparent 1px);
    background-size: 25% 25%;
    opacity: 0.5;
    pointer-events: none;
  }
  .cmp-map__axis {
    position: absolute;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--k-text-muted);
    white-space: nowrap;
  }
  .cmp-map__axis--x {
    left: 50%;
    bottom: 0.7rem;
    transform: translateX(-50%);
  }
  .cmp-map__axis--y {
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%) rotate(180deg);
    writing-mode: vertical-rl;
  }
  .cmp-node {
    position: absolute;
    transform: translate(-50%, 50%);
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    color: var(--k-text-2);
    white-space: nowrap;
  }
  .cmp-node::before {
    content: '';
    flex: none;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--k-text-muted);
  }
  .cmp-node--knomit {
    color: var(--k-brand);
    font-weight: 600;
    font-size: 0.98rem;
  }
  .cmp-node--knomit::before {
    width: 13px;
    height: 13px;
    background: var(--k-brand);
    box-shadow: 0 0 0 5px var(--k-brand-glow);
  }
  .cmp-note {
    margin-top: 1.25rem;
    text-align: center;
    font-size: 0.95rem;
  }

  /* ── Cluster cards ───────────────────────────────────────────────── */
  .cmp-clusters {
    background: var(--k-surface-1);
    border-block: 1px solid var(--k-hairline-soft);
  }
  .cmp-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.25rem;
  }
  .cmp-card {
    border: 1px solid var(--k-hairline);
    border-radius: var(--k-radius);
    padding: 1.4rem;
    background: var(--k-bg);
  }
  .cmp-card--brand {
    border-color: rgba(119, 204, 153, 0.3);
    background:
      radial-gradient(130% 120% at 0% 0%, var(--k-brand-glow), transparent 60%),
      var(--k-bg);
  }
  .cmp-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    color: var(--k-brand);
    background: var(--k-brand-glow);
    border: 1px solid rgba(119, 204, 153, 0.25);
    margin-bottom: 0.9rem;
  }
  .cmp-card__title {
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
  }
  .cmp-card__profile {
    line-height: 1.6;
    font-size: 0.94rem;
  }
  .cmp-card__row {
    display: flex;
    gap: 0.7rem;
    margin-top: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .cmp-card__row p {
    color: var(--k-text-2);
  }
  .cmp-card__k {
    flex: none;
    width: 4.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding-top: 0.1rem;
  }
  .cmp-card__k--yes {
    color: var(--k-brand);
  }
  .cmp-card__k--no {
    color: var(--k-text-muted);
  }

  /* ── Refinery ────────────────────────────────────────────────────── */
  .cmp-callout {
    margin: 2.5rem auto 0;
    max-width: 44rem;
    text-align: center;
    font-size: var(--k-step-lead);
    line-height: 1.5;
    color: var(--k-text-2);
  }
  .cmp-callout strong {
    color: var(--k-text);
  }
  .cmp-underneath {
    margin: 1.5rem auto 0;
    max-width: 44rem;
    text-align: center;
    font-size: 0.94rem;
    line-height: 1.65;
  }

  /* ── Honest fit ──────────────────────────────────────────────────── */
  .cmp-fit {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .cmp-fit__col {
    border: 1px solid var(--k-hairline);
    border-radius: var(--k-radius);
    padding: 1.5rem 1.6rem;
    background: var(--k-surface-1);
  }
  .cmp-fit__col--yes {
    border-color: rgba(119, 204, 153, 0.4);
    background:
      radial-gradient(120% 140% at 0% 0%, var(--k-brand-glow), transparent 55%),
      var(--k-surface-1);
  }
  .cmp-fit__head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }
  .cmp-fit__col--yes .cmp-fit__head :global(.k-icon) {
    color: var(--k-brand);
  }
  .cmp-fit__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .cmp-fit__list li {
    position: relative;
    padding-left: 1.1rem;
    line-height: 1.5;
    font-size: 0.94rem;
    color: var(--k-text-2);
  }
  .cmp-fit__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--k-text-muted);
  }
  .cmp-fit__col--yes .cmp-fit__list li::before {
    background: var(--k-brand);
  }

  /* ── CTA ─────────────────────────────────────────────────────────── */
  .cmp-cta {
    text-align: center;
  }
  .cmp-cta h2 {
    font-size: var(--k-step-h2);
    margin-bottom: 1rem;
  }
  .cmp-cta__lead {
    margin: 0 auto 2rem;
    max-width: 40rem;
  }
  .cmp-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .cmp-map {
      height: 360px;
    }
    .cmp-node {
      font-size: 0.72rem;
    }
    .cmp-fit {
      grid-template-columns: 1fr;
    }
  }
</style>
