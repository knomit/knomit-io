            <text x="6" y="146" font-size="8" fill="var(--k-ref)" font-family="monospace" opacity="0.85">agent/</text>
            <text x="6" y="157" font-size="8" fill="var(--k-ref)" font-family="monospace" opacity="0.85">mindev</text>
            <text x="6" y="168" font-size="7.5" fill="var(--k-ref)" font-family="monospace" opacity="0.6">.local-8ef0cd32</text>
            <text x="352" y="148" font-size="8" fill="var(--k-brand-2)" font-family="monospace" opacity="0.85">agent/</text>
            <text x="352" y="159" font-size="8" fill="var(--k-brand-2)" font-family="monospace" opacity="0.85">research-7f3</text>
            <!-- Commit op labels -->
            <text x="120" y="132" font-size="7.5" fill="var(--k-text-muted)" font-family="monospace">learn</text>
