            <circle cx="230" cy="72" r="5" fill="var(--k-brand)"/>
            <circle cx="230" cy="100" r="5" fill="var(--k-brand)"/>
            <circle cx="230" cy="238" r="5" fill="var(--k-brand)"/>
            <circle cx="230" cy="272" r="7" fill="var(--k-brand)" filter="url(#bg-glow)"/>
            <circle cx="230" cy="318" r="5" fill="var(--k-brand)"/>
            <!-- Branch A commits (left) -->
