            <line x1="130" y1="62" x2="190" y2="38" stroke="var(--k-text-muted)" stroke-width="1" stroke-dasharray="2 6" opacity="0.3"/>
            <line x1="268" y1="62" x2="212" y2="38" stroke="var(--k-text-muted)" stroke-width="1" stroke-dasharray="2 6" opacity="0.3"/>
            <!-- Cluster A: ai/agents (green) — varying sizes -->
            <circle cx="88" cy="152" r="10" fill="var(--k-brand)" opacity="0.85" filter="url(#cg1)"/>
            <circle cx="122" cy="164" r="14" fill="var(--k-brand)" opacity="0.85" filter="url(#cg1)"/>
            <circle cx="98" cy="182" r="8" fill="var(--k-brand)" opacity="0.75"/>
            <circle cx="130" cy="194" r="9" fill="var(--k-brand)" opacity="0.75"/>
            <circle cx="64" cy="172" r="6" fill="var(--k-brand)" opacity="0.6"/>
