            <line x1="88" y1="152" x2="64" y2="172" stroke="var(--k-brand)" stroke-width="1" opacity="0.18"/>
            <line x1="122" y1="164" x2="148" y2="178" stroke="var(--k-brand)" stroke-width="1" opacity="0.18"/>
            <line x1="268" y1="148" x2="300" y2="156" stroke="var(--k-ref)" stroke-width="1" opacity="0.22"/>
            <line x1="300" y1="156" x2="284" y2="176" stroke="var(--k-ref)" stroke-width="1" opacity="0.22"/>
            <line x1="284" y1="176" x2="318" y2="166" stroke="var(--k-ref)" stroke-width="1" opacity="0.22"/>
            <line x1="268" y1="148" x2="246" y2="162" stroke="var(--k-ref)" stroke-width="1" opacity="0.18"/>
