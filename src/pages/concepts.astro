            <text x="24" y="148" font-size="9" fill="var(--k-brand)" font-family="monospace" opacity="0.8">ai/agents</text>
            <text x="326" y="148" font-size="9" fill="var(--k-ref)" font-family="monospace" opacity="0.8">security/ai</text>
            <text x="158" y="264" font-size="9" fill="var(--k-temporal)" font-family="monospace" opacity="0.8">business</text>
