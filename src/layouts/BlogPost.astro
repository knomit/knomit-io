---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/format';
import { blogPostingSchema } from '../lib/schema';
import '../styles/prose.css';

interface Props {
  post: CollectionEntry<'blog'>;
  prev?: { href: string; title: string };
  next?: { href: string; title: string };
}
const { post, prev, next } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, heroImage } =
  post.data;

const site = Astro.site!;
const url = new URL(Astro.url.pathname, site);
const ogImage = new URL('/og.png', site);
const jsonLd = blogPostingSchema({
  site,
  url,
  title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate?.toISOString(),
  author,
  image: ogImage,
});
---

<BaseLayout title={`${title} — knomit blog`} description={description} article={true} jsonLd={jsonLd}>
  <article class="post">
    <div class="k-container post__head">
      <a href="/blog" class="post__back k-mono">← Blog</a>
      <h1 class="post__title">{title}</h1>
      <p class="k-lead post__desc">{description}</p>
      <div class="post__meta k-mono">
        <span>{author}</span>
        <span class="post__sep">·</span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {
          updatedDate && (
            <>
              <span class="post__sep">·</span>
              <span class="post__updated">updated {formatDate(updatedDate)}</span>
            </>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <ul class="post__tags">
            {tags.map((t) => (
              <li class="k-tag k-mono">{t}</li>
            ))}
          </ul>
        )
      }
    </div>

    {
      heroImage && (
        <div class="k-container post__hero">
          <Image src={heroImage} alt={title} widths={[480, 800, 1120]} loading="eager" />
        </div>
      )
    }

    <div class="k-container">
      <div class="post__body k-prose-content">
        <slot />
      </div>
    </div>

    <div class="k-container">
      <nav class="post__nav" aria-label="Post navigation">
        {
          prev ? (
            <a href={prev.href} class="post__navlink post__navlink--prev">
              <span class="k-mono k-muted">← Previous</span>
              <span>{prev.title}</span>
            </a>
          ) : (
            <span />
          )
        }
        {
          next && (
            <a href={next.href} class="post__navlink post__navlink--next">
              <span class="k-mono k-muted">Next →</span>
              <span>{next.title}</span>
            </a>
          )
        }
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .post__head {
    max-width: var(--k-maxw-prose);
    margin-inline: auto;
    padding-top: 3rem;
  }
  .post__back {
    font-size: 0.85rem;
    color: var(--k-text-2);
  }
  .post__title {
    font-size: var(--k-step-h1);
    margin: 1rem 0 0.9rem;
  }
  .post__desc {
    margin-bottom: 1.25rem;
  }
  .post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--k-text-muted);
  }
  .post__updated {
    color: var(--k-temporal);
  }
  .post__sep {
    opacity: 0.5;
  }
  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 1.1rem 0 0;
    padding: 0;
  }
  .post__hero {
    max-width: var(--k-maxw-prose);
    margin-inline: auto;
    margin-top: 2rem;
  }
  .post__hero :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--k-radius);
    border: 1px solid var(--k-hairline-soft);
  }
  .post__body {
    max-width: var(--k-maxw-prose);
    margin-inline: auto;
    margin-top: 2.5rem;
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .post__nav {
    max-width: var(--k-maxw-prose);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--k-hairline-soft);
  }
  .post__navlink {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    color: var(--k-text);
    font-size: 0.95rem;
    max-width: 48%;
  }
  .post__navlink--next {
    text-align: right;
    margin-left: auto;
  }
</style>
